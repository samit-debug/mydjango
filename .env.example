DEBUG=False
PYTHON_VERSION=3.14.3
SECRET_KEY=change-this-secret-key
ALLOWED_HOSTS=mydjango-f5uc.onrender.com,hiti-library.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://mydjango-f5uc.onrender.com,https://hiti-library.onrender.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SERVE_MEDIA_FILES=True
RUN_MIGRATIONS_ON_START=True
WHITENOISE_USE_FINDERS=True
DATABASE_URL=postgresql://user:password@host:5432/database
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=owner@hiti-library.local
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password

# Local fallback only
DATABASE_ENGINE=postgresql
POSTGRES_DB=hiti_library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=8388
